import os
import pandas as pd
import numpy as np
import wrds

# -----------------------------
# 1. Configuration (Top 50 US Tech Stocks)
# -----------------------------
START_DATE = "2010-01-01"
END_DATE = "2026-03-31"
OUTPUT_DIR = "wrds_output_v3"

# Top 50 Technology Stocks (including Big Tech, Semiconductors, Cloud, AI, Cybersecurity, FinTech)
TECH_TICKERS_50 = [
    # --- Big Tech & Platforms ---
    "AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA", "NFLX",

    # --- Semiconductors & Equipment (AI Core) ---
    "AVGO", "AMD", "INTC", "QCOM", "MU", "TXN", "ADI", "ASML", "AMAT",
    "LRCX", "KLAC", "MRVL", "ARM", "TSM",

    # --- Cloud, Software & AI Applications ---
    "ORCL", "CRM", "ADBE", "NOW", "PLTR", "SNPS", "CDNS", "WDAY",
    "TEAM", "INTU", "SHOP", "DDOG", "NET",

    # --- Hardware & Infrastructure ---
    "CSCO", "IBM", "ORCL", "ANET", "VERT", "DELL", "HPE", "SMCI",

    # --- Cybersecurity ---
    "PANW", "CRWD", "FTNT", "ZS",

    # --- FinTech & High-Growth Tech ---
    "PYPL", "SQ", "UBER", "ABNB"
]

# Remove duplicates (safety check)
TECH_TICKERS_50 = list(set(TECH_TICKERS_50))

# -----------------------------
# 2. WRDS Data Extraction
# -----------------------------
def get_wrds_connection():
    """Establish connection to WRDS database"""
    return wrds.Connection()


def fetch_data(db):
    print(f"Starting data extraction for {len(TECH_TICKERS_50)} tech stocks...")

    ticker_list = "'" + "','".join(TECH_TICKERS_50) + "'"

    # --- CRSP Monthly Stock Data ---
    crsp_sql = f"""
        SELECT a.permno, a.date, n.ticker, a.ret, a.prc, a.shrout
        FROM crsp.msf AS a
        LEFT JOIN crsp.msenames AS n
            ON a.permno = n.permno
            AND n.namedt <= a.date AND a.date <= n.nameendt
        WHERE a.date BETWEEN '{START_DATE}' AND '{END_DATE}'
            AND n.shrcd IN (10, 11)
            AND n.exchcd IN (1, 2, 3)
            AND n.ticker IN ({ticker_list})
    """
    crsp = db.raw_sql(crsp_sql, date_cols=['date'])

    # Data cleaning
    crsp['prc'] = crsp['prc'].abs()
    crsp['ret'] = pd.to_numeric(crsp['ret'], errors='coerce')  # handle non-numeric values
    crsp['me_usd_mils'] = (crsp['prc'] * crsp['shrout']) / 1000

    # --- Compustat Financial Data ---
    funda_sql = f"""
        SELECT gvkey, datadate, fyear, tic, seq, ceq, at, lt, ni,
               dltt, dlc, xrd, cogs, revt
        FROM comp.funda
        WHERE datadate BETWEEN '{START_DATE}' AND '{END_DATE}'
            AND indfmt='INDL'
            AND datafmt='STD'
            AND popsrc='D'
            AND consol='C'
    """
    funda = db.raw_sql(funda_sql, date_cols=['datadate'])

    # --- CCM Linking Table ---
    ccm_sql = """
        SELECT gvkey, lpermno AS permno, linkdt, linkenddt
        FROM crsp.ccmxpf_linktable
        WHERE linktype IN ('LU', 'LC')
    """
    ccm = db.raw_sql(ccm_sql, date_cols=['linkdt', 'linkenddt'])
    ccm['linkenddt'] = ccm['linkenddt'].fillna(pd.Timestamp('2026-12-31'))

    return crsp, funda, ccm


# -----------------------------
# 3. Data Processing
# -----------------------------
def process_panel(crsp, funda, ccm):
    print("Processing and merging multi-dimensional financial data...")

    # --- Step 1: Link Compustat with CCM ---
    funda = funda.merge(ccm, on='gvkey')
    funda = funda[
        (funda['datadate'] >= funda['linkdt']) &
        (funda['datadate'] <= funda['linkenddt'])
    ]

    # Apply 6-month lag (financial reporting delay)
    funda['public_date'] = funda['datadate'] + pd.DateOffset(months=6)

    # --- Step 2: Match CRSP with Compustat ---
    crsp['permno'] = crsp['permno'].astype(int)
    funda['permno'] = funda['permno'].astype(int)

    def match_logic(group):
        permno = group['permno'].iloc[0]
        f_sub = funda[funda['permno'] == permno].sort_values('public_date')
        if f_sub.empty:
            return group

        return pd.merge_asof(
            group.sort_values('date'),
            f_sub,
            left_on='date',
            right_on='public_date',
            direction='backward'
        )

    merged = crsp.groupby('permno', group_keys=False).apply(match_logic)

    # --- Step 3: Compute Financial Ratios ---
    merged['roa'] = merged['ni'] / merged['at']
    merged['gross_margin'] = (merged['revt'] - merged['cogs']) / merged['revt']
    merged['rnd_to_rev'] = merged['xrd'].fillna(0) / merged['revt']
    merged['bm_ratio'] = (
        merged['seq'].fillna(merged['ceq']) / merged['me_usd_mils']
    )

    # Final dataset
    final_cols = [
        'date', 'ticker', 'prc', 'ret',
        'me_usd_mils', 'roa', 'gross_margin',
        'rnd_to_rev', 'bm_ratio'
    ]

    return (
        merged[final_cols]
        .dropna(subset=['ticker', 'ret'])
        .sort_values(['ticker', 'date'])
    )


# -----------------------------
# 4. Execution
# -----------------------------
if __name__ == "__main__":
    os.makedirs(OUTPUT_DIR, exist_ok=True)

    conn = get_wrds_connection()

    try:
        crsp, funda, ccm = fetch_data(conn)
        final_df = process_panel(crsp, funda, ccm)

        output_path = os.path.join(OUTPUT_DIR, "us_tech_top50_2026.csv")
        final_df.to_csv(output_path, index=False)

        print("\n" + "★" * 30)
        print("Data extraction completed successfully!")
        print("Includes emerging tech leaders such as PLTR, SMCI, VERT, etc.")
        print(f"Total rows: {len(final_df)}")
        print(f"Saved to: {output_path}")
        print("★" * 30)

    finally:
        conn.close()
